# ========== Database ==========
DATABASE_URL="file:./data/dev.db"

# ========== NextAuth ==========
# Phase 1: 用 NextAuth Credentials (单 admin)
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ========== Admin (单 admin, P1 阶段) ==========
ADMIN_EMAIL="admin@obsidian.local"
ADMIN_PASSWORD_HASH="$2a$10$placeholder_replace_with_bcrypt_hash"

# ========== Deployment Mode (v0.4 §13.4) ==========
# dev | prod-16g | prod-4g
DEPLOY_MODE="dev"

# ========== Performance (随部署档调整) ==========
# sharp 并发: dev=4 / prod-16g=4 / prod-4g=1
SHARP_CONCURRENCY=4
# Node heap 上限 (MB): dev=4096 / prod-16g=2048 / prod-4g=1536
NODE_MAX_OLD_SPACE_MB=4096

# ========== Tunnel (P1.7 演示通道) ==========
# 老板本地收藏用, 不入仓
DEV_TUNNEL_URL=""

# ========== Site (公开信息, P1 占位) ==========
NEXT_PUBLIC_SITE_NAME="黑曜石日志"
NEXT_PUBLIC_SITE_TAGLINE="用代码与数据说话"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"