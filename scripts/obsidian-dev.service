[Unit]
Description=Obsidian-Journal Next.js Dev Server (dev.shangkun.uk origin)
Documentation=https://github.com/blackclaw0318/obsidian-journal
After=network.target
# Wait for cloudflared named tunnel to be up before serving (avoid 502 during boot)
After=cloudflared.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/projects/obsidian-journal
ExecStart=/usr/bin/npm run dev
Restart=always
RestartSec=5
# Graceful shutdown on stop
KillSignal=SIGTERM
TimeoutStopSec=15
# Log
StandardOutput=append:/var/log/obsidian-dev.log
StandardError=append:/var/log/obsidian-dev.log
# Env (NODE_ENV=development is npm run dev default; we set NODE_OPTIONS for sqlite compat)
Environment=NODE_ENV=development
Environment=NODE_OPTIONS=--experimental-sqlite
# Open file limit
LimitNOFILE=65536
# Don't depend on a TTY (we run as daemon)
StandardInput=null
TTYPath=/dev/null

[Install]
WantedBy=multi-user.target